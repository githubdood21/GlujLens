<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:vm="using:GlujLens.ViewModels"
        x:Class="GlujLens.Views.MainWindow"
        mc:Ignorable="d"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="500"
        Title="GlujLens - Screenshot Utility"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <Design.Resources>
        <!-- Placeholder styles for design-time -->
    </Design.Resources>

    <Grid RowDefinitions="Auto, *, Auto">
        <!-- Top Toolbar -->
        <StackPanel Grid.Row="0">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="10">
                <Button Content="Capture Screen" 
                        Command="{Binding CaptureCommand}"
                        Classes="accent"
                        MinWidth="140"/>
                <Button Content="Copy to Clipboard" 
                        Command="{Binding CopyToClipboardCommand}"
                        MinWidth="150"/>
                <Button Content="Save Image" 
                        Command="{Binding SaveImageCommand}"
                        MinWidth="120"/>
                <Button Content="Run OCR"
                        Command="{Binding RunOcrCommand}"
                        MinWidth="110"/>
                <Button Content="Translate Screenshot"
                        Command="{Binding TranslateScreenshotCommand}"
                        MinWidth="150"/>
                <Button Content="Clear Results" 
                        Command="{Binding ClearResultsCommand}"/>
                <Button Content="Settings" 
                        Command="{Binding OpenSettingsCommand}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        Margin="10,0,10,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsOcrProcessing}">
                <TextBlock Text="OCR"
                           VerticalAlignment="Center"
                           FontSize="12"/>
                <ProgressBar Width="140"
                             Height="6"
                             IsIndeterminate="True"
                             VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal"
                        Spacing="8"
                        Margin="10,0,10,8"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsVisible="{Binding IsTranslationProcessing}">
                <TextBlock Text="Translation"
                           VerticalAlignment="Center"
                           FontSize="12"/>
                <ProgressBar Width="140"
                             Height="6"
                             IsIndeterminate="True"
                             VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- Main Content Area - Split into Capture Preview and AI Results -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 400">
            <!-- Left: Screenshot Preview / Capture Area -->
            <Border Grid.Column="0" 
                    Margin="10" 
                    Background="{DynamicResource SystemControlPageBackgroundAltBrush}"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource SystemControlForegroundMediumBrush}"
                    BorderThickness="1">
                <Grid>
                    <!-- Placeholder text - always present, visible when no image -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                x:Name="PlaceholderPanel"
                                IsVisible="{Binding !HasCapturedImage}">
                        <TextBlock Text="Screenshot Preview" 
                                   FontSize="24" 
                                   Foreground="{DynamicResource SystemControlBaseHighBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
                        <TextBlock Text="Click 'Capture Screen' to take a screenshot" 
                                   FontSize="14" 
                                   Foreground="{DynamicResource SystemControlBaseHighBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <!-- Captured image with OCR overlay. The Viewbox scales original pixel coordinates. -->
                    <Viewbox Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             IsVisible="{Binding HasCapturedImage}">
                        <Grid Width="{Binding CapturedImageWidth}"
                              Height="{Binding CapturedImageHeight}">
                            <Image Source="{Binding CapturedImage}"
                                   Width="{Binding CapturedImageWidth}"
                                   Height="{Binding CapturedImageHeight}"
                                   Stretch="Fill"/>
                            <ItemsControl ItemsSource="{Binding TextRegions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.Styles>
                                    <Style Selector="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                        <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                                    </Style>
                                </ItemsControl.Styles>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="{Binding Width}"
                                              Height="{Binding Height}">
                                            <Button Width="{Binding Width}"
                                                    Height="{Binding Height}"
                                                    MinWidth="0"
                                                    MinHeight="0"
                                                    Padding="0"
                                                    Background="#55FFE166"
                                                    BorderBrush="#DDFFE166"
                                                    BorderThickness="1"
                                                    Command="{Binding $parent[Window].DataContext.SelectTextRegionCommand}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip.Tip="{Binding Text}">
                                                <TextBlock Text=""/>
                                            </Button>
                                            <Border IsVisible="{Binding HasTranslatedText}"
                                                    Background="{Binding TranslationBackground}"
                                                    CornerRadius="2"
                                                    Padding="2"
                                                    IsHitTestVisible="False">
                                                <TextBlock Text="{Binding TranslatedText}"
                                                           Foreground="{Binding TranslationForeground}"
                                                           FontSize="{Binding TranslationFontSize}"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           MaxWidth="{Binding Width}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Viewbox>
                    <!-- Capture duration overlay -->
                    <Border Background="#80000000"
                            Padding="5,3"
                            CornerRadius="3"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="10"
                            IsVisible="{Binding HasCapturedImage}">
                        <TextBlock Text="{Binding CaptureDuration}" 
                                   FontSize="12"
                                   Foreground="White"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: AI Results Panel -->
            <Border Grid.Column="1" 
                    Margin="10,10,0,10"
                    Background="{DynamicResource SystemControlPageBackgroundAltBrush}"
                    CornerRadius="8"
                    BorderBrush="{DynamicResource SystemControlForegroundMediumBrush}"
                    BorderThickness="1">
                <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="12">
                    <TextBlock Grid.Row="0"
                               Text="Inspector"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <StackPanel Grid.Row="1" Spacing="6">
                        <TextBlock Text="Selected Text" FontWeight="Bold"/>
                        <TextBox Text="{Binding SelectedOcrText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 MinHeight="90"/>
                        <Button Content="Translate Selected"
                                Command="{Binding TranslateSelectedTextCommand}"
                                HorizontalAlignment="Left"
                                MinWidth="130"
                                Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Spacing="6" Margin="0,14,0,0">
                        <TextBlock Text="Selected Translation" FontWeight="Bold"/>
                        <TextBox Text="{Binding SelectedTranslatedText}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 IsReadOnly="True"
                                 MinHeight="130"/>
                        <TextBlock Text="Manual selected translation does not alter the screenshot overlay."
                                   FontSize="11"
                                   Foreground="Gray"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3"
                               Text="{Binding StatusText}"
                               Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource SystemControlBaseHighBrush}"/>
                    <Grid IsVisible="False">
                    <!-- Tab Header -->
                    <TabControl Grid.Row="0" Margin="10">
                        <TabItem Header="Detection">
                            <ListBox ItemsSource="{Binding DetectedObjects}" 
                                     Margin="5">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBlock Text="{Binding Label}" 
                                                       FontWeight="Bold"/>
                                            <TextBlock Text="{Binding Confidence}" 
                                                       Opacity="0.7"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </TabItem>
                        <TabItem Header="OCR Text">
                            <Grid RowDefinitions="Auto,*" Margin="5">
                                <StackPanel Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="Selected Text" FontWeight="Bold"/>
                                    <TextBox Text="{Binding SelectedOcrText}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             MinHeight="48"/>
                                </StackPanel>
                                <TextBox Grid.Row="1"
                                         Text="{Binding ExtractedText}" 
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"/>
                            </Grid>
                        </TabItem>
                        <TabItem Header="Translation">
                            <StackPanel Margin="5">
                                <TextBox Text="{Binding TranslatedText}" 
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         IsReadOnly="True"/>
                                <Button Content="Translate" 
                                        Command="{Binding TranslateTextCommand}"
                                        Margin="0,10,0,0"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>

                    <!-- Status Bar -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding StatusText}"
                               Margin="10"
                               Foreground="{DynamicResource SystemControlBaseHighBrush}"/>
                </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" 
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="10,5">
            <TextBlock Text="Ready" 
                       x:Name="StatusbarText"
                       Foreground="{DynamicResource SystemControlBaseHighBrush}"/>
        </Border>
    </Grid>
</Window>
